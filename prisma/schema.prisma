generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  CONSUMER
  BUSINESS_OWNER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  PENDING
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// Users
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  avatar        String?
  role          UserRole  @default(CONSUMER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  business        Business?
  reviews         Review[]
  bookings        Booking[]
  quoteRequests   QuoteRequest[]
  favorites       Favorite[]
  messages        Message[]       @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  notifications   Notification[]
}

// Service Categories
model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  image       String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  businesses  Business[]
  services    Service[]
}

// Business Listings
model Business {
  id              String   @id @default(cuid())
  ownerId         String   @unique
  name            String
  slug            String   @unique
  description     String?
  shortDescription String?
  phone           String?
  email           String?
  website         String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  latitude        Float?
  longitude       Float?
  serviceRadius   Int?     // in miles
  priceRange      Int?     // 1-4 ($-$$$$)
  yearEstablished Int?
  licenseNumber   String?
  insured         Boolean  @default(false)
  verified        Boolean  @default(false)
  featured        Boolean  @default(false)
  active          Boolean  @default(true)
  avgRating       Float    @default(0)
  reviewCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  owner           User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  categories      Category[]
  services        Service[]
  photos          BusinessPhoto[]
  videos          BusinessVideo[]
  hours           BusinessHours[]
  reviews         Review[]
  bookings        Booking[]
  quoteRequests   QuoteRequest[]
  leads           Lead[]
  serviceAreas    ServiceArea[]
  favorites       Favorite[]
  messages        Message[]
  analytics       BusinessAnalytics[]
  advertisements  Advertisement[]
}

// Business Photos
model BusinessPhoto {
  id          String   @id @default(cuid())
  businessId  String
  url         String
  caption     String?
  isPrimary   Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// Business Videos
model BusinessVideo {
  id          String   @id @default(cuid())
  businessId  String
  url         String
  title       String?
  thumbnail   String?
  createdAt   DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// Business Hours
model BusinessHours {
  id          String    @id @default(cuid())
  businessId  String
  dayOfWeek   DayOfWeek
  openTime    String?   // HH:MM format
  closeTime   String?   // HH:MM format
  isClosed    Boolean   @default(false)

  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
}

// Service Areas
model ServiceArea {
  id          String   @id @default(cuid())
  businessId  String
  city        String
  state       String
  zipCode     String?

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, city, state])
}

// Services offered by businesses
model Service {
  id          String   @id @default(cuid())
  businessId  String
  categoryId  String
  name        String
  description String?
  price       Float?
  priceType   String?  // "fixed", "hourly", "quote"
  duration    Int?     // in minutes
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id])
  bookings    Booking[]
}

// Reviews
model Review {
  id            String       @id @default(cuid())
  businessId    String
  userId        String
  rating        Int          // 1-5
  title         String?
  content       String
  pros          String?
  cons          String?
  status        ReviewStatus @default(PENDING)
  isVerified    Boolean      @default(false)
  helpfulCount  Int          @default(0)
  aiSentiment   String?      // positive, neutral, negative
  aiScore       Float?       // 0-1 sentiment score
  isFlagged     Boolean      @default(false)
  flagReason    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos        ReviewPhoto[]
  response      ReviewResponse?
}

// Review Photos
model ReviewPhoto {
  id        String   @id @default(cuid())
  reviewId  String
  url       String
  caption   String?
  createdAt DateTime @default(now())

  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

// Business Response to Reviews
model ReviewResponse {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

// Bookings
model Booking {
  id          String        @id @default(cuid())
  businessId  String
  userId      String
  serviceId   String?
  date        DateTime
  startTime   String        // HH:MM
  endTime     String?       // HH:MM
  status      BookingStatus @default(PENDING)
  notes       String?
  totalPrice  Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  service     Service?      @relation(fields: [serviceId], references: [id])
}

// Quote Requests
model QuoteRequest {
  id          String      @id @default(cuid())
  businessId  String
  userId      String
  serviceDescription String
  details     String?
  preferredDate DateTime?
  budget      String?
  status      QuoteStatus @default(PENDING)
  aiEstimate  Float?      // AI-generated price estimate
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote       Quote?
}

// Quotes from businesses
model Quote {
  id              String       @id @default(cuid())
  quoteRequestId  String       @unique
  price           Float
  description     String
  validUntil      DateTime
  createdAt       DateTime     @default(now())

  quoteRequest    QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
}

// Favorites
model Favorite {
  id          String   @id @default(cuid())
  userId      String
  businessId  String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
}

// Messages
model Message {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  businessId  String?
  subject     String?
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  business    Business? @relation(fields: [businessId], references: [id])
}

// Notifications
model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // booking, review, message, lead, etc.
  title       String
  message     String
  link        String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Leads for businesses
model Lead {
  id          String     @id @default(cuid())
  businessId  String
  name        String
  email       String
  phone       String?
  source      String?    // search, referral, ad, etc.
  status      LeadStatus @default(NEW)
  aiScore     Float?     // AI-generated lead quality score (0-1)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// Business Analytics
model BusinessAnalytics {
  id            String   @id @default(cuid())
  businessId    String
  date          DateTime @db.Date
  views         Int      @default(0)
  searches      Int      @default(0)
  clicks        Int      @default(0)
  calls         Int      @default(0)
  bookings      Int      @default(0)
  quoteRequests Int      @default(0)

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
}

// Advertisements
model Advertisement {
  id          String   @id @default(cuid())
  businessId  String
  type        String   // featured, banner, sponsored
  startDate   DateTime
  endDate     DateTime
  budget      Float
  spent       Float    @default(0)
  clicks      Int      @default(0)
  impressions Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// AI Chat Sessions
model ChatSession {
  id        String   @id @default(cuid())
  sessionId String   @unique
  messages  Json     // Array of {role, content}
  context   Json?    // Search context, preferences, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
